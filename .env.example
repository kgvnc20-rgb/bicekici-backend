# ─── BiÇekici Backend — Environment Variables ───
# Copy this to .env and fill in real values

DATABASE_URL="postgresql://user:password@localhost:5433/bicekici_db?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET="CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING"
PORT=3001

# ─── External Services ───
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000

# ─── CORS (production only — comma-separated origins) ───
# ALLOWED_ORIGINS=https://bicekici.com,https://admin.bicekici.com

# ─── Rate Limiting (defaults: 100 req/60s) ───
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# ─── Payment Provider ───
# 'sandbox' (default) | 'iyzico' (future)
PAYMENT_PROVIDER=sandbox

# ─── SMS Provider ───
# 'console' (default) | 'netgsm' (future)
SMS_PROVIDER=console

# ─── Dev Admin Seed ───
SEED_ADMIN=true
ADMIN_EMAIL=admin@bicekici.com
ADMIN_PASSWORD=Admin123!

# ─── Iyzico (when PAYMENT_PROVIDER=iyzico) ───
# Sandbox: https://sandbox-api.iyzipay.com
# Production: https://api.iyzipay.com
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxxxxxxxxxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

