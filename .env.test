# ─── BiÇekici Backend — TEST Environment ───
# Used by: npm run test:e2e
# Separate DB + Redis to avoid polluting dev data

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/bicekici_test?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=15
JWT_SECRET="test-jwt-secret-do-not-use-in-production-64chars-aaaaaaaaaaaaaaaa"
PORT=3099

# ─── External Services (mocked/stubbed in tests) ───
GOOGLE_MAPS_API_KEY=test_key
MAPBOX_ACCESS_TOKEN=test_token

# ─── Frontend ───
FRONTEND_URL=http://localhost:3000

# ─── Providers (always sandbox in tests) ───
PAYMENT_PROVIDER=sandbox
SMS_PROVIDER=console
PUSH_PROVIDER=noop

# ─── Rate Limiting (disabled in tests) ───
THROTTLE_TTL=60000
THROTTLE_LIMIT=9999

# ─── Seed ───
SEED_ADMIN=false
