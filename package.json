  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --selectProjects unit",
    "test:watch": "jest --selectProjects unit --watch",
    "test:e2e": "dotenv -e .env.test -- jest --selectProjects e2e --runInBand --forceExit",
    "test:e2e:reset": "dotenv -e .env.test -- npx prisma migrate reset --force --skip-seed",
    "test:all": "jest --selectProjects unit && npm run test:e2e",
    "test:cov": "jest --selectProjects unit --coverage"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nestjs/axios": "^4.0.1",
