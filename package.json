    "class-validator": "^0.14.0",
    "dotenv": "^17.2.4",
    "ioredis": "^5.9.3",
    "iyzipay": "^2.0.65",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
